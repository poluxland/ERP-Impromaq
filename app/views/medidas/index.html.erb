    <% @medidas.each do |medida| %>
      <% # ---- calculados producción ----
   haver_unid = medida.prodhaver.to_f
   haver_hrs  = medida.horas_haver.to_f
   haver_ton  = haver_unid * factor_saco_ton
   haver_tonh = haver_hrs > 0 ? (haver_ton / haver_hrs) : 0
   haver_cumpl = objetivo[:haver].to_f > 0 ? [(haver_unid * 100 / objetivo[:haver]), 100].min : 0

   vento_unid = medida.prodvento.to_f
   vento_hrs  = medida.horas_vento.to_f
   vento_ton  = vento_unid * factor_saco_ton
   vento_tonh = vento_hrs > 0 ? (vento_ton / vento_hrs) : 0
   vento_cumpl = objetivo[:vento].to_f > 0 ? [(vento_unid * 100 / objetivo[:vento]), 100].min : 0

   bb_unid = medida.prodbb.to_f
   bb_hrs  = medida.horas_bigbag.to_f
   bb_ton  = bb_unid * factor_bb_ton
   bb_tonh = bb_hrs > 0 ? (bb_ton / bb_hrs) : 0
   bb_cumpl = objetivo[:bigbag].to_f > 0 ? [(bb_unid * 100 / objetivo[:bigbag]), 100].min : 0
%>


